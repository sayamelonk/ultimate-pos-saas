# ===========================================
# ULTIMATE POS - PRODUCTION ENVIRONMENT
# ===========================================
# Copy this file to .env on your production server
# and fill in the values

APP_NAME="Ultimate POS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://yourdomain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ===========================================
# DATABASE (MySQL/MariaDB recommended)
# ===========================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ultimate_pos_production
DB_USERNAME=your_db_user
DB_PASSWORD=your_secure_password

# ===========================================
# SESSION & CACHE (Redis recommended)
# ===========================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================
# QUEUE (Redis recommended for production)
# ===========================================
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ===========================================
# BREVO EMAIL CONFIGURATION
# ===========================================
# 1. Login to https://app.brevo.com
# 2. Go to Settings > SMTP & API
# 3. Generate a new SMTP key
# 4. MAIL_USERNAME = your Brevo login email
# 5. MAIL_PASSWORD = the generated SMTP key
#
# IMPORTANT: Verify your domain in Brevo for better deliverability
# Settings > Senders, Domains & Dedicated IPs > Add Domain

MAIL_MAILER=brevo
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-email@example.com
MAIL_PASSWORD=xsmtpsib-xxxxxxxx-your-smtp-key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="Ultimate POS"

# ===========================================
# XENDIT PAYMENT GATEWAY
# ===========================================
XENDIT_SECRET_KEY=xnd_production_xxxxx
XENDIT_PUBLIC_KEY=xnd_public_production_xxxxx
XENDIT_WEBHOOK_TOKEN=your-webhook-token
XENDIT_IS_PRODUCTION=true

# ===========================================
# L5 SWAGGER / API DOCS
# ===========================================
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST="${APP_URL}"
